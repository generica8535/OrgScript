{
  "name": "orgscript-vscode",
  "displayName": "OrgScript",
  "description": "Minimal VS Code language support for OrgScript (.orgs) files.",
  "version": "0.9.3",
  "publisher": "dkfuh",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DKFuH/OrgScript"
  },
  "bugs": {
    "url": "https://github.com/DKFuH/OrgScript/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "orgscript",
        "aliases": [
          "OrgScript",
          "orgscript"
        ],
        "extensions": [
          ".orgs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "orgscript",
        "scopeName": "source.orgscript",
        "path": "./syntaxes/orgscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "orgscript",
        "path": "./snippets/orgscript.code-snippets"
      }
    ]
  }
}
