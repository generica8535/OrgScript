{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OrgScript",
  "scopeName": "source.orgscript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#document-header"
    },
    {
      "include": "#document-metadata"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#top-level-blocks"
    },
    {
      "include": "#section-keywords"
    },
    {
      "include": "#control-keywords"
    },
    {
      "include": "#statement-keywords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#references"
    }
  ],
  "repository": {
    "document-header": {
      "patterns": [
        {
          "match": "^(\\s*)(orgscript)(\\s+)(1)\\b",
          "captures": {
            "2": {
              "name": "keyword.declaration.orgscript"
            },
            "4": {
              "name": "constant.numeric.orgscript"
            }
          }
        }
      ]
    },
    "document-metadata": {
      "patterns": [
        {
          "match": "^(\\s*)(source-language|comment-language|annotation-language|context-language)(\\s+)(\"(?:[^\"\\\\]|\\\\.)*\")",
          "captures": {
            "2": {
              "name": "keyword.other.special-method.orgscript"
            },
            "4": {
              "name": "string.quoted.double.orgscript"
            }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "match": "^(\\s*)(#).*$",
          "captures": {
            "2": {
              "name": "punctuation.definition.comment.orgscript"
            }
          },
          "name": "comment.line.number-sign.orgscript"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "match": "^(\\s*)(@[a-z][a-z0-9_]*)(\\s+)(\"(?:[^\"\\\\]|\\\\.)*\")",
          "captures": {
            "2": {
              "name": "storage.type.annotation.orgscript"
            },
            "4": {
              "name": "string.quoted.double.orgscript"
            }
          }
        }
      ]
    },
    "top-level-blocks": {
      "patterns": [
        {
          "match": "^(\\s*)(process|stateflow|rule|role|policy|metric|event)(\\s+)([A-Za-z_][A-Za-z0-9_.-]*)",
          "captures": {
            "2": {
              "name": "storage.type.orgscript"
            },
            "4": {
              "name": "entity.name.type.orgscript"
            }
          }
        }
      ]
    },
    "section-keywords": {
      "patterns": [
        {
          "match": "^(\\s*)(states|transitions|can|cannot|formula|owner|target)\\b",
          "captures": {
            "2": {
              "name": "keyword.declaration.orgscript"
            }
          }
        },
        {
          "match": "^(\\s*)(applies\\s+to)\\b",
          "captures": {
            "2": {
              "name": "keyword.declaration.orgscript"
            }
          }
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "match": "\\b(else\\s+if)\\b",
          "name": "keyword.control.conditional.orgscript"
        },
        {
          "match": "\\b(if|then|else)\\b",
          "name": "keyword.control.conditional.orgscript"
        },
        {
          "match": "\\b(when)\\b",
          "name": "keyword.control.orgscript"
        },
        {
          "match": "\\b(with|to|and|or)\\b",
          "name": "keyword.operator.word.orgscript"
        }
      ]
    },
    "statement-keywords": {
      "patterns": [
        {
          "match": "^(\\s*)(assign|transition|notify|create|update|require|stop)\\b",
          "captures": {
            "2": {
              "name": "keyword.control.statement.orgscript"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.orgscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.orgscript",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.orgscript"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b-?\\d+(?:\\.\\d+)?\\b",
          "name": "constant.numeric.orgscript"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "->",
          "name": "keyword.operator.arrow.orgscript"
        },
        {
          "match": "(!=|<=|>=|=|<|>)",
          "name": "keyword.operator.comparison.orgscript"
        }
      ]
    },
    "references": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_-]*)((?:\\.[A-Za-z_][A-Za-z0-9_-]*)+)\\b",
          "captures": {
            "1": {
              "name": "variable.other.object.orgscript"
            },
            "2": {
              "name": "variable.other.property.orgscript"
            }
          }
        }
      ]
    }
  }
}
